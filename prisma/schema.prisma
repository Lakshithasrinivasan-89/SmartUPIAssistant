generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("vendor")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions    Transaction[]
  expenses        Expense[]
  inventoryItems  InventoryItem[]
  assistantQueries AssistantQuery[]
  alerts          Alert[]
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  messageText     String?
  amount          Float
  type            String   // credit, debit
  category        String   @default("income") // income, expense, refund, supplier, unknown
  customerName    String?
  sourceApp       String?  // GPay, PhonePe, Paytm, etc.
  transactionTime DateTime @default(now())
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  category    String   // rent, electricity, stock, transport, misc
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model InventoryItem {
  id            String   @id @default(cuid())
  userId        String
  name          String
  category      String?
  stockQuantity Int      @default(0)
  costPrice     Float
  sellingPrice  Float
  reorderLevel  Int      @default(5)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model AssistantQuery {
  id        String   @id @default(cuid())
  userId    String
  query     String
  response  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Alert {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // low_stock, sales_dip, peak_hour, top_selling
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model SalesSummary {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime @default(now())
  totalSales     Float
  totalExpenses  Float
  estimatedProfit Float
  transactionCount Int
}
